{
  "name": "de.convey.lsmobilecdv",
  "displayName": "LeadSuccess",
  "version": "1.0.0",
  "description": "A sample Apache Cordova application that responds to the deviceready event.",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "ecosystem:cordova"
  ],
  "author": "Apache Cordova Team",
  "license": "Apache-2.0",
  "devDependencies": {
    "@thegrizzlylabs/cordova-plugin-genius-scan": "^5.17.4",
    "cordova-android": "^14.0.1",
    "cordova-ios": "^8.0.0",
    "cordova-plugin-appinfo": "^2.1.2",
    "cordova-plugin-camera": "^8.0.0",
    "cordova-plugin-customurlscheme": "^5.0.2",
    "cordova-plugin-device": "^3.0.0",
    "cordova-plugin-file": "^8.1.3",
    "cordova-plugin-globalization": "^1.11.0",
    "cordova-plugin-inappbrowser": "^6.0.0",
    "cordova-plugin-media-capture": "^6.0.0",
    "cordova-plugin-network-information": "^3.0.0",
    "cordova-plugin-splashscreen": "^6.0.2",
    "cordova-plugin-statusbar": "^4.0.0",
    "cordova-plugin-x-socialsharing": "^6.0.4",
    "cordova-sqlite-storage": "^7.0.0",
    "es6-promise-plugin": "^4.2.2",
    "phonegap-plugin-barcodescanner": "github:conveyGmbH/phonegap-plugin-barcodescanner"
  },
  "cordova": {
    "platforms": [
      "ios",
      "android"
    ],
    "plugins": {
      "cordova-plugin-camera": {
        "ANDROIDX_CORE_VERSION": "1.6.+"
      },
      "cordova-plugin-device": {},
      "cordova-plugin-file": {
        "ANDROIDX_WEBKIT_VERSION": "1.4.0"
      },
      "cordova-plugin-inappbrowser": {},
      "cordova-plugin-splashscreen": {},
      "cordova-plugin-statusbar": {},
      "cordova-sqlite-storage": {},
      "cordova-plugin-globalization": {},
      "cordova-plugin-media-capture": {},
      "cordova-plugin-appinfo": {},
      "es6-promise-plugin": {},
      "phonegap-plugin-barcodescanner": {
        "CAMERA_USAGE_DESCRIPTION": "To scan barcodes"
      },
      "@thegrizzlylabs/cordova-plugin-genius-scan": {
        "CAMERA_USAGE_DESCRIPTION": "This app needs camera access"
      },
      "cordova-plugin-x-socialsharing": {
        "PHOTO_LIBRARY_ADD_USAGE_DESCRIPTION": "This app requires photo library access to function properly.",
        "PHOTO_LIBRARY_USAGE_DESCRIPTION": "This app requires photo library access to function properly."
      },
      "cordova-plugin-network-information": {},
      "cordova-plugin-customurlscheme": {
        "URL_SCHEME": "myapp",
        "ANDROID_HOST": "auth",
        "ANDROID_SCHEME": " ",
        "ANDROID_PATHPREFIX": "/"
      }
    }
  }
}